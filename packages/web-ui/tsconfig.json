{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "allowJs": false,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "paths": {
      "@iron-scribe/model": ["../model/src/index.ts"],
      "@iron-scribe/data/ancestries": ["../data/src/raw/core/ancestries/index.ts"],
      "@iron-scribe/data/skills": ["../data/src/skills/core/skills.ts"],
      "@iron-scribe/data/rules/damage": ["../data/src/raw/rules/damage.ts"],
      "@iron-scribe/data": ["../data/src/index.ts"],
      "@iron-scribe/ui-shared": ["../ui-shared/src/index.ts"]
    }
  },
  "include": ["src"],
  "references": [
    { "path": "./tsconfig.node.json" },
    { "path": "../model" },
    { "path": "../data" },
    { "path": "../ui-shared" }
  ]
}
